# Copy to .env.local and fill in.

# Supabase (public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# FastAPI service URL (Railway or localhost for dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: direct URL to a hosted sample report HTML
# NEXT_PUBLIC_SAMPLE_URL=https://<supabase-storage>/test_nollm.html
